# npm compatibility
legacy-peer-deps=true
# ignore-scripts=true

# pnpm-specific settings
auto-install-peers=true
shamefully-hoist=false

# Build script control (only these packages can run build scripts)
# only-built-dependencies[]=sharp
# only-built-dependencies[]=unrs-resolver
# only-built-dependencies[]=msgpackr-extract

minimum-release-age=3
