{
  "name": "nextjs-woocommerce",
  "version": "1.2.5",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "lhci": "lhci autorun",
    "lhci:perf": "lhci autorun --collect.settings.preset=perf",
    "lhci:desktop": "lhci autorun --collect.settings.preset=desktop",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"**/*.{js,ts,tsx,json}\"",
    "playwright": "pnpm exec playwright test",
    "playwright:ui": "pnpm exec playwright test --ui",
    "playwright:debug": "pnpm exec playwright test --debug",
    "playwright:codegen": "pnpm exec playwright codegen",
    "doctor": "echo n | react-doctor --verbose",
    "doctor:score": "echo n | react-doctor --score",
    "refresh": "rm -rf node_modules && rm pnpm-lock.yaml && pnpm install && pnpm run format"
  },
  "keywords": [
    "next.js",
    "portfolio",
    "next",
    "javascript",
    "framer"
  ],
  "author": "w3bdesign",
  "license": "AGPL-3.0",
  "dependencies": {
    "@apollo/client": "^3.14.1",
    "@types/react": "^19.2.16",
    "algoliasearch": "^5.53.0",
    "autoprefixer": "^10.5.0",
    "graphql": "^16.14.1",
    "motion": "^12.40.0",
    "next": "16.2.7",
    "nprogress": "^0.2.0",
    "postcss": "^8.5.15",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.77.0",
    "react-instantsearch-dom": "^6.40.4",
    "uuid": "^14.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "25.9.1",
    "@types/nprogress": "^0.2.3",
    "@types/react-instantsearch-dom": "^6.12.9",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "babel-plugin-styled-components": "^2.3.0",    
    "postcss-preset-env": "^11.3.0",
    "prettier": "^3.8.3",
    "react-doctor": "^0.3.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3"
  }
}
